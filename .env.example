# ============================================
# Supabase (obrigatório desde a Fase 1)
# Pegue esses valores em: supabase.com > seu projeto > Project Settings > API
# ============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave secreta (nunca expor no navegador) - usada para criar/gerenciar usuários como admin
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# Anthropic (só necessário a partir da Fase 4 - leitura automática de cupons)
# Gere em: console.anthropic.com > API Keys
# ============================================
ANTHROPIC_API_KEY=

# ============================================
# Google Drive (só necessário a partir da Fase 4 - pasta "Notinhas e Cupons")
# Crie uma Service Account no Google Cloud Console, gere uma chave JSON,
# e compartilhe a pasta do Drive com o e-mail dessa conta de serviço.
# ============================================
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=
